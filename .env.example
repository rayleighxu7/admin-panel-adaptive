# --- Database ---
# SQLite (default, local development)
DATABASE_URL=sqlite:///./sqlite.db

# MySQL
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/admin_panel

# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/admin_panel

# --- App ---
SECRET_KEY=change-me-in-production
DEBUG=true
ENABLE_AUTH=true
SESSION_COOKIE_NAME=admin_panel_session
SESSION_MAX_AGE_SECONDS=28800
SESSION_HTTPS_ONLY=false

# NOTE:
# Create your first admin user manually with:
# uv run python scripts/create_admin_user.py --username admin

# --- Branding (hex colours) ---
BRAND_PRIMARY=#206bc4
BRAND_SIDEBAR_BG=#1b2434
BRAND_SIDEBAR_TEXT=#ffffff
BRAND_ACCENT=#206bc4
BRAND_DANGER=#d63939
BRAND_SUCCESS=#2fb344
